apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: "{{ addon_name }}"
  namespace: argocd
  labels:
    app.kubernetes.io/name: "{{ addon_name }}"
    app.kubernetes.io/managed-by: argocd
    app.kubernetes.io/part-of: addons
spec:
  goTemplate: true
  generators:
    - clusters: {}
  template:
    metadata:
      name: "{{ addon_name }}-{{ '{{' }} .name {{ '}}' }}"
      labels:
        app.kubernetes.io/name: "{{ addon_name }}"
        app.kubernetes.io/managed-by: argocd
        app.kubernetes.io/part-of: addons
    spec:
      project: addons
      destination:
        server: "{{ '{{' }} .server {{ '}}' }}"
        namespace: "{{ addon_namespace }}"
      source:
        repoURL: {{ repo_url }}
        targetRevision: {{ target_revision }}
        path: "kubernetes/addons/{{ addon_name }}"
        helm:
          releaseName: "{{ addon_name }}"
          valueFiles:
            - values/common.yaml
            - "values/{{ '{{' }} .name {{ '}}' }}.yaml"
          ignoreMissingValueFiles: true
      syncPolicy:
        automated:
          prune: true
          selfHeal: true
        syncOptions:
          - CreateNamespace=true
          - ApplyOutOfSyncOnly=true
  templatePatch: |
    metadata:
      name: "{{ addon_name }}-{{ '{{' }} .name {{ '}}' }}"
      {% if annotations %}
      annotations:
        {% for k, v in annotations.items() %}
        {{ k }}: "{{ v }}"
        {% endfor %}
      {% endif %}
    spec:
      syncPolicy:
        {% if extra_sync_options %}
        syncOptions:
          - CreateNamespace=true
          - ApplyOutOfSyncOnly=true
          {% for opt in extra_sync_options %}
          - {{ opt }}
          {% endfor %}
        {% endif %}
        {% if retry %}
        retry:
{{ retry_yaml }}
        {% endif %}
